# Copy to .env and fill in values.
#
# Generate SHARED_PASSWORD_HASH with:
#   .venv/Scripts/python -c "import bcrypt; print(bcrypt.hashpw(b'your_password', bcrypt.gensalt()).decode())"
#
# Generate JWT_SECRET with:
#   .venv/Scripts/python -c "import secrets; print(secrets.token_hex(32))"

APP_ENV=development
SHARED_PASSWORD_HASH=
JWT_SECRET=
